# Context Bharat — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git (it's in .gitignore)

# ─────────────────────────────────────────────
# DATABASE (Supabase)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...              # Service role key — server only, never expose to browser
SUPABASE_ANON_KEY=eyJ...                 # Anon key — safe for frontend
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# AI / LLM APIS
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...                    # Required — used for text-embedding-3-small
COHERE_API_KEY=...                       # Required — used for Rerank v3
SARVAM_API_KEY=...                       # Required for Hindi translation — get at sarvam.ai

# Optional: Anthropic for enrichment (Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# REDIS (Upstash)
# ─────────────────────────────────────────────
UPSTASH_REDIS_URL=rediss://...
UPSTASH_REDIS_TOKEN=...

# ─────────────────────────────────────────────
# CRAWLING
# ─────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                     # GitHub personal access token — higher rate limits for crawling

# For authenticated government portals (if needed)
# PORTAL_ABDM_USERNAME=
# PORTAL_ABDM_PASSWORD=

# ─────────────────────────────────────────────
# MCP SERVER
# ─────────────────────────────────────────────
CONTEXTBHARAT_API_BASE_URL=https://api.contextbharat.com
# For local development:
# CONTEXTBHARAT_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────
# INTERNAL AUTH
# ─────────────────────────────────────────────
INTERNAL_API_KEY=...                     # Used by GitHub Actions to call our API
JWT_SECRET=...                           # For signing internal tokens — generate with: openssl rand -hex 32

# ─────────────────────────────────────────────
# DEPLOYMENT (Railway)
# ─────────────────────────────────────────────
RAILWAY_TOKEN=...                        # Railway API token for deployments

# ─────────────────────────────────────────────
# MONITORING (Optional but recommended)
# ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # Ingestion failure alerts
SENTRY_DSN=https://...                   # Error tracking

# ─────────────────────────────────────────────
# BILLING (Stripe — Phase 2)
# ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─────────────────────────────────────────────
# FRONTEND (Next.js public vars)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_BASE_URL=https://api.contextbharat.com

# ─────────────────────────────────────────────
# LOCAL DEV OVERRIDES
# ─────────────────────────────────────────────
# Uncomment for local development:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contextbharat
# UPSTASH_REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_TOKEN=local
# CELERY_TASK_ALWAYS_EAGER=true          # Run Celery tasks synchronously in tests
